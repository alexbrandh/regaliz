# Supabase (auth + database + storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Uploads
# Max size validated en frontend y backend
MAX_FILE_SIZE_MB=50
NEXT_PUBLIC_MAX_FILE_SIZE_MB=50
# Timeout de subida en ms (frontend)
NEXT_PUBLIC_UPLOAD_TIMEOUT_MS=120000

# Icon rewrites (middleware)
# When true, middleware may rewrite icon routes. Defaults to false so App Routes serve icons directly.
ENABLE_ICON_REWRITE=false